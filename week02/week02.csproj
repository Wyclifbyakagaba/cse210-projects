<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <!--
    The root week02 project lives alongside sibling sample projects (Journal/ and Resumes/).
    The SDK-style default include pattern ("**/*.cs") would otherwise compile their sources too,
    leading to duplicate types (Program) and duplicate assembly attributes.
  -->
  <ItemGroup>
    <Compile Remove="Journal\**\*.cs" />
    <Compile Remove="Resumes\**\*.cs" />
  </ItemGroup>

</Project>
